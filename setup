    prompt_value WEB_SEARCH_API_KEY \
      "Google API key for web search" \
      1 1 "${WEB_SEARCH_API_KEY:-${GOOGLE_API_KEY:-$DEFAULT_WEB_SEARCH_API_KEY}}" \
      "AIza..." \
      "" \
      validator_any
  else
    ENABLE_WEB=0
    info "Skipped. Enable later with ${BOLD}./setup configure${RESET}"
  fi
}

