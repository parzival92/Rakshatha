(scripts_dir / "call_user.sh").write_text(source_call)
(scripts_dir / "call_user.sh").chmod(0o755)
(scripts_dir / "add_rakshatha_crons.sh").chmod(0o755)

agents_text = (repo / "AGENTS.md").read_text()
