existing_profiles = existing_auth_profiles.get("profiles") or {}

def clone_existing_provider_profiles(provider: str):
    cloned = {}
    for profile_id, profile in existing_profiles.items():
        if not isinstance(profile, dict):
            continue
        if (profile.get("provider") or "").strip() != provider:
            continue
        cloned[profile_id] = profile
    return cloned

if openai_key:
    auth_profiles["profiles"]["openai:default"] = {
        "type": "api_key",
        "provider": "openai",
