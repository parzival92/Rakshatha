    auth_profiles["usageStats"]["openai:default"] = auth_profiles["usageStats"].get("openai:default", {"errorCount": 0})
elif default_openai_profile_present:
    auth_profiles["profiles"].update(clone_existing_provider_profiles("openai"))

if google_key:
    auth_profiles["profiles"]["google:default"] = {
        "type": "api_key",
        "provider": "google",
        "key": google_key,
    }
    auth_profiles["lastGood"]["google"] = "google:default"
    auth_profiles["usageStats"]["google:default"] = {
        "errorCount": 0,
    }
elif default_google_profile_present:
    auth_profiles["profiles"].update(clone_existing_provider_profiles("google"))

if not auth_profiles["profiles"]:
    raise RuntimeError("No auth profiles available to write. Re-run setup with valid provider credentials.")

(agent_dir / "auth-profiles.json").write_text(json.dumps(auth_profiles, indent=2) + "\n")
PY
}

# ─────────────────────────────────────────────────────────────
# Telegram pairing
# ─────────────────────────────────────────────────────────────

fetch_telegram_chat_details() {
  curl -fsS "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/getUpdates" | python3 - <<'PY'
import json
import sys

try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(1)

for update in reversed(data.get("result", [])):
    msg = (
        update.get("message")
        or update.get("edited_message")
        or update.get("channel_post")
        or update.get("edited_channel_post")
    )
    if not isinstance(msg, dict):
        continue
    chat = msg.get("chat") or {}
    if chat.get("type") != "private":
        continue
    chat_id = chat.get("id")
    if chat_id is None:
        continue
    username = chat.get("username") or ""
    print(f"{chat_id}|{username}")
    break
PY
}

render_agents_only() {
  export REPO_ROOT TARGET_WORKSPACE USER_NAME TELEGRAM_USERNAME TELEGRAM_CHAT_ID USER_PHONE
  python3 - <<'PY'
import os
import pathlib

repo = pathlib.Path(os.environ["REPO_ROOT"])
workspace = pathlib.Path(os.environ["TARGET_WORKSPACE"])

text = (repo / "AGENTS.md").read_text()
text = text.replace("<user-name>", os.environ["USER_NAME"])
text = text.replace("<telegram-username>", os.environ["TELEGRAM_USERNAME"])
text = text.replace("<telegram-chat-id>", os.environ["TELEGRAM_CHAT_ID"])
text = text.replace("<user-phone-number>", os.environ["USER_PHONE"])
(workspace / "AGENTS.md").write_text(text)
PY
}

approve_pairing() {
  local pairing_code="$1"
  local output
  local status=0
  local maybe_chat_id=""

  output="$(openclaw pairing approve telegram "$pairing_code" 2>&1)" || status=$?
  printf '%s\n' "$output"

  if [[ "$status" -ne 0 ]]; then
    return "$status"
  fi

  maybe_chat_id="$(printf '%s\n' "$output" | grep -Eo -- '-?[0-9]+' | tail -n 1 || true)"
  if [[ -n "$maybe_chat_id" ]]; then
    TELEGRAM_CHAT_ID="$maybe_chat_id"
    good "Captured Telegram chat ID from pairing: $TELEGRAM_CHAT_ID"
  fi

  return 0
}

handle_pairing() {
  section "Telegram Pairing"

  info "Almost there! Let's connect your Telegram account."
  echo
  echo "  ${BOLD}1.${RESET} Open Telegram and find your new bot"
  echo "  ${BOLD}2.${RESET} Send it a message (anything, like \"hi\")"
  echo "  ${BOLD}3.${RESET} Come back here and paste the pairing code"
  echo
  hint "The pairing code appears in your terminal where OpenClaw is running."
  echo

  read -r -p "  Press Enter after you've sent the message..."

  if prompt_yes_no "Do you have a pairing code to approve now?" "Y"; then
    prompt_value PAIRING_CODE \
      "Paste the pairing code" \
      0 1 "" \
      "Q4WFN6R3" \
      "" \
      validator_any

    if ! approve_pairing "$PAIRING_CODE"; then
      warn "Pairing did not complete cleanly. You can retry later."
    fi
  else
    echo
    info "No problem. Approve it later with:"
    printf '  %s$ openclaw pairing approve telegram <PAIRING_CODE>%s\n' "$CYAN" "$RESET"
  fi

  CHAT_DETAILS="$(fetch_telegram_chat_details || true)"
  if [[ -n "$CHAT_DETAILS" ]]; then
    if [[ "$TELEGRAM_CHAT_ID" == "pending-pairing" ]]; then
      TELEGRAM_CHAT_ID="${CHAT_DETAILS%%|*}"
    fi
    DETECTED_USERNAME="${CHAT_DETAILS#*|}"
    if [[ -n "$DETECTED_USERNAME" ]]; then
      TELEGRAM_USERNAME="$DETECTED_USERNAME"
      good "Detected Telegram username: @$TELEGRAM_USERNAME"
    fi
  fi

  if [[ "$TELEGRAM_CHAT_ID" == "pending-pairing" ]]; then
    warn "Could not auto-detect your Telegram chat ID."
    prompt_value TELEGRAM_CHAT_ID \
      "Telegram chat ID" \
      0 1 "$DEFAULT_TELEGRAM_CHAT_ID" \
      "123456789" \
      "You can find this in the pairing output or via the Telegram Bot API." \
      validator_chat_id
  fi

  if [[ "$TELEGRAM_USERNAME" == "not-set" || -z "$TELEGRAM_USERNAME" ]]; then
    prompt_value TELEGRAM_USERNAME \
      "Telegram username without @ (optional)" \
      0 0 "$DEFAULT_TELEGRAM_USERNAME" \
      "notyourabhi" \
      "" \
      validator_any
    if [[ -z "$TELEGRAM_USERNAME" ]]; then
      TELEGRAM_USERNAME="not-set"
    fi
  fi

  render_agents_only
  good "Telegram details saved."
}

# ─────────────────────────────────────────────────────────────
# Gateway reload
# ─────────────────────────────────────────────────────────────

reload_gateway() {
  section "Restarting OpenClaw"
  install_step "Restarting gateway..."
  if ! openclaw gateway restart >/dev/null 2>&1; then
    printf '\n'
    warn "Restart did not complete cleanly. Trying fresh start."
    openclaw gateway start >/dev/null 2>&1 || true
  fi

  if openclaw gateway probe >/dev/null 2>&1; then
    install_done "Gateway restarted"
  else
    ensure_gateway_running
  fi
}

upgrade_openclaw() {
  local backup_stamp
  local upgrade_choice
  local update_target_label
  local -a update_args
  backup_stamp="$(date +%Y%m%d-%H%M%S)"

  section "Upgrading OpenClaw"
  info "This will back up the active config, update OpenClaw, and restart the gateway."
  echo
  echo "  ${BOLD}1${RESET}  Latest stable      ${DIM}(recommended, tracks the stable channel)${RESET}"
  echo "  ${BOLD}2${RESET}  Specific version    ${DIM}(one-off version or tag, like 2026.4.9 or beta)${RESET}"
  echo

  while true; do
    printf '  %s%s%s  Pick an upgrade target [1-2]: ' "$CYAN" ">" "$RESET"
    read -r upgrade_choice
    case "$upgrade_choice" in
      1)
        update_target_label="latest stable"
        update_args=(--channel stable --no-restart --yes)
        break
        ;;
      2)
        prompt_value OPENCLAW_UPDATE_TAG \
          "OpenClaw version or tag" \
          0 1 "" \
          "2026.4.9" \
          "You can also use tags like beta or main for a one-off update target." \
          validator_any
        update_target_label="$OPENCLAW_UPDATE_TAG"
        update_args=(--tag "$OPENCLAW_UPDATE_TAG" --no-restart --yes)
        break
        ;;
      *)
        warn "Please enter 1 or 2."
        ;;
    esac
  done

  if ! prompt_yes_no "Continue with OpenClaw upgrade to $update_target_label?" "Y"; then
    die "Upgrade cancelled."
  fi

  mkdir -p "$TARGET_ROOT" "$TARGET_AGENT_DIR"

  install_step "Backing up active config..."
  cp "$TARGET_ROOT/openclaw.json" "$TARGET_ROOT/openclaw.json.pre-upgrade-${backup_stamp}.bak" 2>/dev/null || true
  cp "$TARGET_AGENT_DIR/auth-profiles.json" "$TARGET_AGENT_DIR/auth-profiles.json.pre-upgrade-${backup_stamp}.bak" 2>/dev/null || true
  install_done "Backups created"

  install_step "Updating OpenClaw ($update_target_label)..."
  if ! openclaw update "${update_args[@]}" >/dev/null 2>&1; then
    printf '\n'
    die "OpenClaw update failed. Run 'openclaw update --dry-run' or the matching update command manually to inspect the error."
  fi
  install_done "OpenClaw updated"

  reload_gateway

  install_step "Checking gateway health..."
  if openclaw gateway probe >/dev/null 2>&1; then
    install_done "Gateway is healthy"
  else
    printf '\n'
    warn "Gateway probe did not pass cleanly. Check with 'openclaw status'."
  fi

  echo
  good "OpenClaw upgrade complete."
  hint "Review health:           ${BOLD}openclaw status${RESET}"
  hint "Deep channel check:      ${BOLD}openclaw status --deep${RESET}"
  echo
}

# ─────────────────────────────────────────────────────────────
# Final screen
# ─────────────────────────────────────────────────────────────

show_complete() {
  echo
  divider
  echo
  printf '%s' "$GREEN$BOLD"
  cat <<'ART'
      Setup complete!
ART
  printf '%s\n' "$RESET"

  info "Rakshatha is now live on Telegram. Send her a message!"
  echo
  hint "Update features anytime:  ${BOLD}./setup configure${RESET}"
  hint "Upgrade OpenClaw:         ${BOLD}./setup configure${RESET} -> ${BOLD}9${RESET}"
  hint "Check system health:      ${BOLD}openclaw status${RESET}"
  echo
  divider
  echo
}

# ─────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# Uninstall
# ─────────────────────────────────────────────────────────────

do_uninstall() {
  init_colors

  echo
  printf '%s%s%s\n' "$BOLD$MAGENTA" "  Rakshatha Uninstall" "$RESET"
  divider
  echo
  warn "This will completely remove Rakshatha and OpenClaw from this machine."
  echo
  echo "  The following will be removed:"
  echo "    ${RED}-${RESET}  OpenClaw gateway (stopped)"
  echo "    ${RED}-${RESET}  OpenClaw installation (openclaw uninstall --all)"
  echo "    ${RED}-${RESET}  OpenClaw global package (npm rm -g openclaw)"
  echo "    ${RED}-${RESET}  All data at ${BOLD}~/.openclaw${RESET} (workspace, config, media, memory)"
  echo

  if ! prompt_yes_no "Are you sure you want to uninstall everything?" "N"; then
    info "Uninstall cancelled."
    exit 0
  fi

  echo
  if ! prompt_yes_no "This cannot be undone. Continue?" "N"; then
    info "Uninstall cancelled."
    exit 0
  fi

  echo
  if command -v openclaw >/dev/null 2>&1; then
    install_step "Stopping gateway..."
    openclaw gateway stop >/dev/null 2>&1 || true
    install_done "Gateway stopped"

    install_step "Uninstalling OpenClaw..."
    openclaw uninstall --all --yes >/dev/null 2>&1 || true
    install_done "OpenClaw uninstalled"

    install_step "Removing global package..."
    npm rm -g openclaw >/dev/null 2>&1 || true
    install_done "Global package removed"
  else
    info "OpenClaw command not found, skipping."
  fi

  install_step "Removing ~/.openclaw..."
  rm -rf "$HOME/.openclaw"
  install_done "~/.openclaw removed"

  echo
  divider
  echo
  good "Rakshatha and OpenClaw have been completely removed."
  echo
}

main() {
  init_colors

  case "$MODE" in
    init|"")
      MODE="init"
      ;;
    configure)
      ;;
    uninstall)
      do_uninstall
      exit 0
      ;;
    help|-h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 1
      ;;
  esac

  need_cmd python3
  need_cmd curl

  export TARGET_ROOT
  load_existing_defaults
  print_banner

  if ! command -v openclaw >/dev/null 2>&1; then
    echo
    warn "OpenClaw is not installed. Install it first with:"
    echo
    echo "    ${CYAN}curl -fsSL https://openclaw.ai/install.sh | bash -s -- --version 2026.4.9 --no-onboard${RESET}"
    echo
    die "Missing required command: openclaw"
  fi

  if [[ "$MODE" == "init" && -f "$TARGET_WORKSPACE/data/state.json" ]]; then
    die "A live Rakshatha workspace already exists at $TARGET_WORKSPACE/data/state.json. Use ./setup configure instead."
  fi

  if [[ "$MODE" == "configure" && ! -f "$TARGET_ROOT/openclaw.json" ]]; then
    warn "No existing install found. Starting fresh install."
    MODE="init"
  fi

  ENABLE_IMAGES=0
  ENABLE_VOICE=0
  ENABLE_CALLS=0
  ENABLE_WEB=0
  ENABLE_DREAMING=0
  GOOGLE_API_KEY=""
  WEB_SEARCH_API_KEY=""
  ELEVENLABS_API_KEY=""
  ELEVENLABS_VOICE_ID=""
  ELEVENLABS_AGENT_ID=""
  ELEVENLABS_PHONE_NUMBER_ID=""
  TELEGRAM_USERNAME="not-set"
  TELEGRAM_CHAT_ID="${DEFAULT_TELEGRAM_CHAT_ID:-pending-pairing}"
  if [[ -z "$TELEGRAM_CHAT_ID" ]]; then
    TELEGRAM_CHAT_ID="pending-pairing"
  fi

  # Track whether crons and pairing should run
  RUN_CRONS=0
  RUN_PAIRING=0

  if [[ "$MODE" == "configure" ]]; then
    show_current_status
    show_configure_menu

    # For options 1-5 and 10, carry forward all defaults first
    carry_forward_all_defaults() {
      ENABLE_IMAGES="$DEFAULT_ENABLE_IMAGES"
      ENABLE_VOICE="$DEFAULT_ENABLE_VOICE"
      ENABLE_WEB="$DEFAULT_ENABLE_WEB"
      ENABLE_DREAMING="$DEFAULT_ENABLE_DREAMING"
      ENABLE_CALLS="$DEFAULT_ENABLE_CALLS"
      GOOGLE_API_KEY="${GOOGLE_API_KEY:-$DEFAULT_GOOGLE_API_KEY}"
      WEB_SEARCH_API_KEY="${WEB_SEARCH_API_KEY:-$DEFAULT_WEB_SEARCH_API_KEY}"
      ELEVENLABS_API_KEY="${ELEVENLABS_API_KEY:-$DEFAULT_ELEVENLABS_API_KEY}"
      ELEVENLABS_VOICE_ID="${ELEVENLABS_VOICE_ID:-${DEFAULT_ELEVENLABS_VOICE_ID:-ulZgFXalzbrnPUGQGs0S}}"
      ELEVENLABS_AGENT_ID="${ELEVENLABS_AGENT_ID:-$DEFAULT_ELEVENLABS_AGENT_ID}"
      ELEVENLABS_PHONE_NUMBER_ID="${ELEVENLABS_PHONE_NUMBER_ID:-$DEFAULT_ELEVENLABS_PHONE_NUMBER_ID}"
    }

    case "$CONFIGURE_CHOICE" in
      1)
        show_core_setup ""
        carry_forward_all_defaults
        ;;
      2)
        show_core_setup_silent
        carry_forward_all_defaults
        configure_images
        ;;
      3)
        show_core_setup_silent
        carry_forward_all_defaults
        configure_voice
        ;;
      4)
        show_core_setup_silent
        carry_forward_all_defaults
        configure_web
        RUN_CRONS=1
        ;;
      5)
        show_core_setup_silent
        carry_forward_all_defaults
        configure_calls
        ;;
      10)
        show_core_setup_silent
        carry_forward_all_defaults
        configure_dreaming
        RUN_CRONS=1
        ;;
      6)
        show_core_setup_silent
        carry_forward_all_defaults
        RUN_CRONS=1
        section "Reinstalling Cron Jobs"
        info "Will reinstall all scheduled jobs after applying config."
        ;;
      7)
        show_core_setup_silent
        carry_forward_all_defaults
        RUN_PAIRING=1
        ;;
      8)
        show_core_setup "6"
        configure_images "6"
        configure_voice "6"
        configure_web "6"
        configure_dreaming "6"
        configure_calls "6"
        RUN_CRONS=1
        RUN_PAIRING=1
        ;;
      9)
        show_core_setup_silent
        carry_forward_all_defaults
        ;;
    esac
  else
    show_core_setup "6"
    configure_images "6"
    configure_voice "6"
    configure_web "6"
    configure_dreaming "6"
    configure_calls "6"
    RUN_CRONS=1
    RUN_PAIRING=1
  fi

  # For cron-only or pairing-only, skip the summary/confirm
  if [[ "$MODE" == "configure" && "$CONFIGURE_CHOICE" == "6" ]]; then
    # Crons only -- skip summary, go straight to install
    :
  elif [[ "$MODE" == "configure" && "$CONFIGURE_CHOICE" == "7" ]]; then
    # Pairing only -- skip summary, go straight to pairing
    :
  elif [[ "$MODE" == "configure" && "$CONFIGURE_CHOICE" == "9" ]]; then
    # Upgrade only -- handled separately
    :
  else
    show_summary

    if ! prompt_yes_no "Continue with this setup?" "Y"; then
      die "Setup cancelled."
    fi
  fi

  if [[ -z "$USER_PHONE" ]]; then
    USER_PHONE="not-shared"
  fi
  if [[ -z "$TELEGRAM_USERNAME" ]]; then
    TELEGRAM_USERNAME="not-set"
  fi

  # For pairing-only, skip file writing entirely
  if [[ "$MODE" == "configure" && "$CONFIGURE_CHOICE" == "7" ]]; then
    handle_pairing

    section "Applying Changes"
    write_runtime_files_agents_only
    reload_gateway
    show_complete
    return 0
  fi

  # For cron-only, skip file writing, just reinstall crons
  if [[ "$MODE" == "configure" && "$CONFIGURE_CHOICE" == "6" ]]; then
    section "Reinstalling Cron Jobs"
    sync_cron_installer_script
    install_step "Adding scheduled jobs (wake-up, life, reflection, discovery)..."
    RAKSHATHA_MAIN_MODEL="$MAIN_MODEL" RAKSHATHA_ENABLE_WEB_SEARCH="$ENABLE_WEB" RAKSHATHA_ENABLE_DREAMING="$ENABLE_DREAMING" "$TARGET_SCRIPTS/add_rakshatha_crons.sh" >/dev/null 2>&1
    install_done "Cron jobs installed"
    show_complete
    return 0
  fi

  if [[ "$MODE" == "configure" && "$CONFIGURE_CHOICE" == "9" ]]; then
    upgrade_openclaw
    return 0
  fi

  GATEWAY_TOKEN="$(generate_gateway_token)"
  SETUP_LAST_RUN_COMMAND="./setup $MODE"

  mkdir -p "$TARGET_ROOT"
  cp "$TARGET_ROOT/openclaw.json" "$TARGET_ROOT/openclaw.json.bak" 2>/dev/null || true
  cp "$TARGET_AGENT_DIR/auth-profiles.json" "$TARGET_AGENT_DIR/auth-profiles.json.bak" 2>/dev/null || true
  backup_existing_workspace_if_needed

  section "Installing"

  install_step "Writing config and workspace files..."
  write_runtime_files
  install_done "Config and workspace files written"

  install_step "Setting permissions..."
  chmod 700 "$TARGET_ROOT" 2>/dev/null || true
  chmod 700 "$TARGET_WORKSPACE" 2>/dev/null || true
  chmod 600 "$TARGET_ROOT/openclaw.json" 2>/dev/null || true
  chmod 600 "$TARGET_AGENT_DIR/auth-profiles.json" 2>/dev/null || true
  install_done "Permissions set"

  ensure_gateway_running

  if [[ "$RUN_CRONS" == "1" ]]; then
    section "Installing Cron Jobs"
    install_step "Adding scheduled jobs (wake-up, life, reflection, discovery)..."
    RAKSHATHA_MAIN_MODEL="$MAIN_MODEL" RAKSHATHA_ENABLE_WEB_SEARCH="$ENABLE_WEB" RAKSHATHA_ENABLE_DREAMING="$ENABLE_DREAMING" "$TARGET_SCRIPTS/add_rakshatha_crons.sh" >/dev/null 2>&1
    install_done "Cron jobs installed"
  fi

  reload_gateway

  if [[ "$RUN_PAIRING" == "1" ]]; then
    handle_pairing
  fi

  show_complete
}

# Write only AGENTS.md (for pairing-only configure)
write_runtime_files_agents_only() {
  render_agents_only
}

# Silent core setup for configure mode (reuses existing values)
show_core_setup_silent() {
  USER_NAME="${DEFAULT_USER_NAME:-}"
  USER_PHONE="${DEFAULT_USER_PHONE:-}"
  TELEGRAM_BOT_TOKEN="${DEFAULT_TELEGRAM_BOT_TOKEN:-}"
  OPENAI_API_KEY="${DEFAULT_OPENAI_API_KEY:-}"

  if [[ -z "$USER_NAME" || -z "$TELEGRAM_BOT_TOKEN" || ( -z "$OPENAI_API_KEY" && "$DEFAULT_OPENAI_PROFILE_PRESENT" != "1" ) ]]; then
    warn "Core settings are incomplete. Let's fill them in first."
    show_core_setup ""
  fi
}

main "$@"
